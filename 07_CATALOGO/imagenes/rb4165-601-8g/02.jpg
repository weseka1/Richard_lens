<script>
  (function () {
    function updateTransparentHeaderOffset() {
      var header = document.querySelector('header');
      if (!header) return;

      var h = header.offsetHeight;
      var heightValue = '-' + h + 'px';

      document.documentElement.style.setProperty('--margin-top-header', heightValue);

      document.querySelectorAll('.section-transparent').forEach(function (section) {
        section.classList.add('header-offset-ready');
      });
    }

    function debounce(fn, ms) {
      var t;
      return function () {
        clearTimeout(t);
        var args = arguments;
        t = setTimeout(function () {
          fn.apply(null, args);
        }, ms);
      };
    }

    var debouncedUpdate = debounce(updateTransparentHeaderOffset, 80);

    document.addEventListener('DOMContentLoaded', function () {
      updateTransparentHeaderOffset();

      window.addEventListener('resize', debouncedUpdate);
      window.addEventListener('orientationchange', debouncedUpdate);
      window.addEventListener('load', updateTransparentHeaderOffset);

      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(updateTransparentHeaderOffset);
      }

      var header = document.querySelector('header');
      if (header && typeof ResizeObserver !== 'undefined') {
        var ro = new ResizeObserver(debouncedUpdate);
        ro.observe(header);
      }
    });
  })();
</script>




