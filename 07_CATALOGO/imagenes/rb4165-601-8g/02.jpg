    <h2 class="AdE54VWVCRENjUmUze__heading_3jzNWk-title title font-primary text-24 md:text-24 text-secondary font-normal md:font-normal leading-tight md:leading-tight tracking-normal text-wrap text-left md:text-left w-full md:w-full" ><p>Welcome to Francis & Gaye Jewellers</p></h2>
      
  </div>


<style data-shopify>

  .AdE54VWVCRENjUmUze__heading_3jzNWk-title em, .AdE54VWVCRENjUmUze__heading_3jzNWk-title i {
