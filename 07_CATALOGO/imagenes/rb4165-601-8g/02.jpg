  :root {
    /* global variables */
    --space-between-sections: 0px;
    /* fonts */
    --font-primary--family: Inter, sans-serif;
    --font-primary--style: normal;
    --font-primary--weight: 400;
    --font-secondary--family: Inter, sans-serif;
    --font-secondary--style: normal;
    --font-secondary--weight: 500;
    --font-tertiary--family: Inter, sans-serif;
    --font-tertiary--style: normal;
    --font-tertiary--weight: 700;
    --font-accent--family: Inter, sans-serif;
    --font-accent--style: normal;
    --font-accent--weight: 400;
    
    
    --page-width-base: 90rem;
    --page-width: 90rem;
    --page-margin: 20px;

    /* Brand Colours */
    --color-primary: #012d6b;
    --color-secondary: #111111;
    --color-tertiary: #c4c4c4;
    --color-accent-1: #505050;
    --color-accent-2: #f1f1f1;
    --color-sale: #ce180f;

    /* Base Colours */
    --color-background: #f1f1f1;
    --color-foreground: #f7f7f7;
    --color-black: #000000;
    --color-white: #FFFFFF;

    /* Text Colours */
    --color-text-primary: #111111;
    --color-text-secondary: #505050;
    --color-text-tertiary: #f2f2f2;
    --color-text-accent-1: #012d6b;
    --color-text-accent-2: #1f1f1f;

    /* Link Colours */
    --color-link: #4494d6;
    --color-link-hover: #385293;

    /* Header & Footer */
    --margin-top-header: 0;
    --announcement-bar-height: 0;
    --color-header-bg: #FFFFFF;
    --color-header-text: #1f1f1f;
    --color-header-transparent-bg: #ffffff00;
    --color-header-transparent-text: #ffffff;
    --color-header-border: #c4c4c4;
    --color-header-transparent-border: #c4c4c4;
    --color-inline-search-bg: #ffffff;
    --color-inline-search-text: #ffffff;
    --color-inline-search-border: #ffffff;
    --color-drawer-bg: #f2f2f2;
    --color-drawer-text: #111111;
    --color-drawer-border: #f5f5f5;
    --color-drawer-header-bg: #ffffff;
    --color-drawer-header-text: #111111;
    --color-drawer-footer-bg: #ffffff;
    --color-drawer-footer-text: #111111;
    --color-footer-border: #f7f7f752;

    /* Buttons */
    --color-button-primary-bg: #06003e;
    --color-button-primary-bg-hover: ;
    --color-button-primary-text: #ffffff;
    --color-button-primary-text-hover: ;
    --color-button-secondary-bg: #efefef;
    --color-button-secondary-bg-hover: ;
    --color-button-secondary-text: #000000;
    --color-button-secondary-text-hover: ;
    --color-button-link-text: ;
    --color-button-link-text-hover: ;

    /* Utility Button Padding */
    --utility-button-padding-top: 8px;
    --utility-button-padding-bottom: 8px;
    --utility-button-padding-left: 16px;
    --utility-button-padding-right: 16px;

    /* Variant Option Buttons */
    --color-variant-button-selected-bg: #012d6b;
    --color-variant-button-selected-text: #ffffff;
    --color-variant-button-selected-border: #012d6b;

    /* Swatches Selected State */
    --color-swatch-selected-ring: #111111;
    --swatch-selected-ring-width: 2px;
    --swatch-selected-ring-offset: 2px;

    /* Badges */
    --color-badge-sale-bg: #ce180f;
    --color-badge-sale-text: #fafafa;
    --color-badge-out-of-stock-bg: #505050;
    --color-badge-out-of-stock-text: #ffffff;

    /* Cards & Sections */
    --color-card-border: #111111;
    --color-card-bg: #fafafa;

    /* Forms & Inputs */
    --color-input-bg: #ffffff;
    --color-input-border: #dfdfdf;
    --color-input-text: #111111;
    --color-input-placeholder: #111111;
    --color-input-focus-border: ;
    --color-input-focus-ring: ;

    /* Cart Shipping Bar */
    --color-cart-shipping-bar-bg: #ffffff;
    --color-cart-shipping-bar-text: #000000;
    --color-cart-shipping-bar-border: #f2f2f2;
    --color-cart-shipping-bar-fill: #012d6b;
    --color-cart-shipping-bar-bar-bg: #f2f2f2;

    /* UI Elements */
    --color-skeleton: rgba(245, 245, 245, 1);
    
    /* Cart Discounts */
    --color-cart-discounts-background: #F2F2F2;
    --color-cart-discounts-text: #000000;

  }
